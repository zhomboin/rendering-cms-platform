# Compose image tag.
APP_IMAGE_TAG=latest

# Frontend container listen address on the server.
# Keep 127.0.0.1:3000 when a host-level Nginx/Caddy terminates HTTPS.
PUBLIC_HTTP_BIND=127.0.0.1:3000

# Local MinIO listen addresses on the server.
# Keep them on 127.0.0.1 and publish them through host-level HTTPS reverse proxies.
MINIO_API_BIND=127.0.0.1:9000
MINIO_CONSOLE_BIND=127.0.0.1:9001

# PostgreSQL container bootstrap values.
POSTGRES_DB=rendering_cms
POSTGRES_USER=rendering
POSTGRES_PASSWORD=replace-with-strong-database-password

# Backend database connection from Docker network.
DATABASE_URL=postgres://rendering:replace-with-strong-database-password@postgres:5432/rendering_cms?sslmode=disable

# Backend runtime.
JWT_SECRET=replace-with-32-plus-character-secret
FRONTEND_ORIGIN=https://cms.example.com
FRONTEND_ORIGINS=https://cms.example.com

# Frontend build-time API base. Keep /api/v1 when frontend Nginx proxies API.
VITE_API_BASE=/api/v1

# Local MinIO object storage.
# S3_ENDPOINT must be reachable by the browser because upload/download URLs are presigned and returned to frontend users.
MINIO_ROOT_USER=rendering
MINIO_ROOT_PASSWORD=replace-with-strong-minio-password
MINIO_BUCKET=rendering-assets
MINIO_SERVER_URL=https://minio.example.com
MINIO_BROWSER_REDIRECT_URL=https://minio-console.example.com

S3_ENDPOINT=https://minio.example.com
S3_REGION=us-east-1
S3_BUCKET=rendering-assets
S3_ACCESS_KEY_ID=rendering
S3_SECRET_ACCESS_KEY=replace-with-strong-minio-password
